{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "vite build && node build-api.mjs",
  "outputDirectory": "dist/public",
  "framework": null,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.mjs" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/index.mjs": {
      "maxDuration": 60
    }
  }
}
